{
  "name": "cck-bill",
  "private": true,
  "scripts": {
    "test": "npm run test:backend && npx playwright test",
    "test:backend": "node --test 'backend/orders/tests/*.test.js'",
    "test:e2e": "playwright test",
    "deploy:all:prod": "node scripts/clasp-deploy.js all production",
    "deploy:all:staging": "node scripts/clasp-deploy.js all staging",
    "deploy:orders:prod": "node scripts/clasp-deploy.js orders production",
    "deploy:orders:staging": "node scripts/clasp-deploy.js orders staging",
    "deploy:ingredients:prod": "node scripts/clasp-deploy.js ingredients production",
    "clasp:login": "clasp login",
    "clasp:pull:orders": "cd backend/orders; clasp pull",
    "clasp:push:orders": "cd backend/orders; clasp push",
    "clasp:push:orders:staging": "cd backend/orders; clasp push --project .clasp.staging.json",
    "clasp:open:orders": "cd backend/orders; clasp open-script",
    "clasp:pull:ingredients": "cd backend/ingredients; clasp pull",
    "clasp:push:ingredients": "cd backend/ingredients; clasp push",
    "clasp:open:ingredients": "cd backend/ingredients; clasp open-script"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@playwright/test": "^1.48.0",
    "serve": "^14.2.0"
  }
}
